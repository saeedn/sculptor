{
  "name": "sculptor",
  "productName": "Sculptor",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --config vite.web.config.ts",
    "build": "vite build -l error --config vite.web.config.ts",
    "lint-compat": "ESLINT_USE_FLAT_CONFIG=false eslint --ext js,ts,jsx,tsx,vue,cjs --report-unused-disable-directives --max-warnings 0 ",
    "tsc": "tsc --noEmit",
    "lint": "eslint --ext js,ts,jsx,tsx,vue,cjs --report-unused-disable-directives --no-warn-ignored --max-warnings 0 --cache --cache-location node_modules/.cache/eslint-lint/ ",
    "preview": "vite preview --config vite.web.config.ts",
    "format": "eslint --fix --no-warn-ignored --cache --cache-location node_modules/.cache/eslint-fix/",
    "prettier-format": "prettier --write",
    "depcheck": "depcheck --ignores=typescript,eslint,prettier,tailwindcss,prettier-plugin-organize-imports",
    "rule-errors": "eslint-config-prettier src/Main.tsx",
    "freeze": "npm list --depth=0",
    "generate-api-json-schema": "uv run python ../../sculptor/sculptor/scripts/generate_json_schema.py ./sculptor_schema.json",
    "fixup-js-types": "uv run python ../../sculptor/sculptor/scripts/fixup_js_types.py ./src/api/types.gen.ts",
    "generate-api": "./scripts/generate-api.sh",
    "test": "vitest run",
    "electron:start": "cross-env SCULPTOR_FRONTEND_DIR=$PWD electron-forge start",
    "preelectron:package": "cd .. && uv run --project sculptor builder sync-frontend-version",
    "electron:package": "electron-forge package",
    "postelectron:package": "cd .. && uv run --project sculptor builder sync-frontend-version --reverse",
    "preelectron:make": "cd .. && uv run --project sculptor builder sync-frontend-version",
    "electron:make": "electron-forge make",
    "postelectron:make": "cd .. && uv run --project sculptor builder sync-frontend-version --reverse",
    "generate-icons": "mkdir -p ./assets/icons && png2icons ./assets/desktop_icon.png ./assets/icons/icon -allp",
    "storybook": "storybook dev -p 6006",
    "storybook:headless": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "lint:styles": "stylelint --cache --cache-location node_modules/.cache/stylelint-lint 'src/**/*.scss'",
    "test:stylelint-plugin": "node --test scripts/stylelint-plugin-design-tokens/rule.test.mjs scripts/stylelint-plugin-design-tokens/no-var-fallback.test.mjs scripts/stylelint-plugin-design-tokens/no-uppercase-custom-property.test.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@floating-ui/dom": "1.7.6",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@pierre/diffs": "1.2.11",
    "@radix-ui/colors": "3.0.0",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-hover-card": "1.1.17",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-toast": "1.2.17",
    "@radix-ui/themes": "3.3.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-virtual": "3.14.3",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "cmdk": "1.1.1",
    "electron-log": "5.4.4",
    "electron-store": "11.0.2",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "get-port": "7.2.0",
    "highlight.js": "11.11.1",
    "jotai": "2.20.1",
    "lodash": "4.18.1",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "3.0.6",
    "react-router-dom": "7.18.0",
    "remark-gfm": "4.0.1",
    "sass": "1.101.0",
    "shiki": "4.2.0",
    "typeid-js": "1.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron/fuses": "1.8.0",
    "@eslint/js": "9.39.4",
    "@hey-api/openapi-ts": "0.98.2",
    "@reforged/maker-appimage": "5.2.0",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/lodash": "4.17.24",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "depcheck": "1.4.7",
    "electron": "42.4.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-css": "0.12.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.6.0",
    "playwright": "1.60.0",
    "png2icons": "2.0.1",
    "prettier": "3.8.4",
    "pureimage": "0.4.18",
    "react-grab": "0.1.47",
    "storybook": "10.4.6",
    "stylelint": "17.13.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "6.4.3",
    "vitest": "4.1.9",
    "jsdom": "29.1.1"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "tar": "^7.5.7",
    "tmp": ">=0.2.6",
    "yauzl": "^3.3.1"
  }
}
